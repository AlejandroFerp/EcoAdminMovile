<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="100dp"
    android:height="100dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Fondo circular verde (degradado) -->
    <path
        android:pathData="M 50 50 m -50 0 a 50 50 0 1 1 100 0 a 50 50 0 1 1 -100 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="100"
                android:endY="100"
                android:type="linear">
                <item android:offset="0" android:color="#FF1A6B3C" />
                <item android:offset="1" android:color="#FF0D4620" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Flecha 1 (arriba derecha) -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.9"
        android:pathData="M 60 30 L 75 45 L 65 50 Q 60 50 58 45 Z" />

    <!-- Flecha 2 (abajo derecha) -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.8"
        android:pathData="M 65 60 L 70 75 L 58 70 Q 55 65 60 58 Z" />

    <!-- Flecha 3 (izquierda) -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.85"
        android:pathData="M 25 50 L 35 35 L 42 48 Q 40 55 32 58 Z" />

    <!-- Circulito central -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.7"
        android:pathData="M 50 50 m -8 0 a 8 8 0 1 1 16 0 a 8 8 0 1 1 -16 0" />
</vector>
